APP_NAME="RLA Dashboard"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.kuhu.org.in
APP_ALLOW_DANGEROUS_SYSTEM=false

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- MySQL (cPanel → MySQL Databases) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kuhuorgi_dashboard
DB_USERNAME=your_mysql_user
DB_PASSWORD="your_mysql_password"

# --- Recommended on shared hosting ---
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

SESSION_LIFETIME=120
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log
MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
AI_ENABLED=false
WHATSAPP_INBOUND_ENABLED=false
PAYMENTS_UPI_ENABLED=true
