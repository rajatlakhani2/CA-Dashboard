APP_NAME="RLA Dashboard"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.kuhu.org.in

# Set true only temporarily to allow web-based migrate from System Health (production).
APP_ALLOW_DANGEROUS_SYSTEM=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production (Spidy): copy .env.spidy.example to .env and set MySQL credentials.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kuhuorgi_dashboard
DB_USERNAME=your_mysql_user
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave empty for localhost; do not use the literal word "null"
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI assistant (partner/manager on client show — optional)
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MAX_TOKENS=800

# WhatsApp inbound bot (Meta webhook — optional)
WHATSAPP_INBOUND_ENABLED=false
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_FIRM_REPLY_NAME="${APP_NAME}"
WHATSAPP_HANDOFF_PHONE=

# UPI payment links on invoices (uses Settings → bank_upi)
PAYMENTS_UPI_ENABLED=true
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
